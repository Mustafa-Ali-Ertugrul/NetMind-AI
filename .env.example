# NetMind AI - Environment Configuration
# Copy this file to .env and adjust values as needed.

# === General ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# === Database ===
POSTGRES_DB=netmind
POSTGRES_USER=netmind
POSTGRES_PASSWORD=netmind
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://netmind:netmind@db:5432/netmind

# === Upload ===
UPLOAD_MAX_SIZE_MB=100
UPLOAD_DIR=/var/lib/netmind/pcaps

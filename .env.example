# NetMind AI - Environment Configuration
# Copy this file to .env and adjust values as needed.

# === General ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# === Database ===
POSTGRES_DB=netmind
POSTGRES_USER=netmind
POSTGRES_PASSWORD=netmind
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://netmind:netmind@db:5432/netmind

# === Upload ===
UPLOAD_MAX_SIZE_MB=100
UPLOAD_DIR=/var/lib/netmind/pcaps

# === Object Storage ===
OBJECT_STORE_BACKEND=local

# Optional MinIO/S3 backend.
# Start it with: docker compose --profile object-storage up --build
# Then set OBJECT_STORE_BACKEND=s3.
S3_ENDPOINT_URL=minio:9000
S3_BUCKET=netmind-pcaps
S3_ACCESS_KEY=netmind
S3_SECRET_KEY=netmind-secret
S3_REGION=us-east-1
MINIO_ROOT_USER=netmind
MINIO_ROOT_PASSWORD=netmind-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === AI Assessor Cache ===
NETMIND_AI_CACHE_ENABLED=true
NETMIND_AI_CACHE_TTL_SECONDS=86400
NETMIND_AI_CACHE_REDIS_URL=redis://redis:6379/2
